{
  "checks": [
    {
      "kind": "file_exists",
      "description": "Project README exists",
      "path": "README.md"
    },
    {
      "kind": "file_min_lines",
      "description": "Project README is substantive",
      "path": "README.md",
      "min_lines": 80
    },
    {
      "kind": "file_exists",
      "description": "Harness manifest exists",
      "path": "agents/agent-harness/harness.json"
    },
    {
      "kind": "file_exists",
      "description": "Routing examples policy exists",
      "path": "agents/agent-harness/policies/routing-examples.md"
    },
    {
      "kind": "file_exists",
      "description": "Preflight checks policy exists",
      "path": "agents/agent-harness/policies/preflight-checks.md"
    },
    {
      "kind": "file_exists",
      "description": "Context refresh policy exists",
      "path": "agents/agent-harness/policies/context-refresh.md"
    },
    {
      "kind": "compile",
      "description": "Coding profile compiles for Codex",
      "profile": "coding",
      "target": "codex"
    },
    {
      "kind": "compile",
      "description": "Coding profile compiles for Claude Code",
      "profile": "coding",
      "target": "claude-code"
    },
    {
      "kind": "compile",
      "description": "Coding profile compiles for IDE assistants",
      "profile": "coding",
      "target": "ide"
    },
    {
      "kind": "compiled_contains",
      "description": "Compiled prompt injects current date runtime context",
      "profile": "coding",
      "target": "codex",
      "text": "## Runtime Context"
    },
    {
      "kind": "compiled_contains",
      "description": "Compiled prompt includes exact URL routing guidance",
      "profile": "coding",
      "target": "codex",
      "text": "exact URL"
    },
    {
      "kind": "file_contains",
      "description": "Research policy includes rate-of-change routing",
      "path": "agents/agent-harness/policies/research.md",
      "text": "## Rate Of Change"
    },
    {
      "kind": "file_contains",
      "description": "Research policy includes unknown entity routing",
      "path": "agents/agent-harness/policies/research.md",
      "text": "## Unknown Entity Rule"
    },
    {
      "kind": "eval",
      "description": "Harness eval files have executable behavior contracts"
    },
    {
      "kind": "py_compile",
      "description": "CLI script compiles",
      "path": "scripts/agent_harness.py"
    },
    {
      "kind": "forbidden_text_absent",
      "description": "Old mistaken agent name is absent",
      "pattern": "Hemess",
      "exclude_paths": ["agents/agent-harness/done_criteria.json"]
    }
  ]
}
